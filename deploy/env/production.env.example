COMPOSE_PROJECT_NAME=offline_doc_extractor
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
OLLAMA_URL=http://ollama:11434/api/generate
OLLAMA_MODEL=llama3.2:3b
REDIS_URL=redis://redis:6379/0
JOB_QUEUE_NAME=extract_jobs
MAX_TEXT_CHARS=5000
USE_LLM_DEFAULT=false
LLM_DISABLE_FOR_FULL_PDF=true
OLLAMA_TIMEOUT_SEC=45
OLLAMA_MAX_RETRIES=0
EXTRACT_MAX_WORKERS=1
FILE_PROCESS_RETRIES=0
OCR_TIMEOUT_SEC=20
OCR_MIN_TEXT_LEN=120
OCR_MAX_PAGES_PER_PDF=2
OCR_RENDER_ZOOM=1.5
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
STORAGE_DIR=storage
