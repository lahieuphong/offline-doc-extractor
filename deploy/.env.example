COMPOSE_PROJECT_NAME=offline_doc_extractor
BACKEND_PORT=8000
FRONTEND_PORT=3000
OLLAMA_URL=http://ollama:11434/api/generate
OLLAMA_MODEL=llama3.2:3b
REDIS_URL=redis://redis:6379/0
JOB_QUEUE_NAME=extract_jobs
MAX_TEXT_CHARS=12000
USE_LLM_DEFAULT=false
LLM_DISABLE_FOR_FULL_PDF=true
OLLAMA_TIMEOUT_SEC=45
OLLAMA_MAX_RETRIES=0
EXTRACT_MAX_WORKERS=1
FILE_PROCESS_RETRIES=1
OCR_TIMEOUT_SEC=45
OCR_MIN_TEXT_LEN=120
OCR_MAX_PAGES_PER_PDF=4
OCR_RENDER_ZOOM=2.5
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
STORAGE_DIR=storage
# OCR metadata tuning for scanned Vietnamese administrative documents
OCR_TESSERACT_PSM=6
OCR_TARGETED_REGIONS=1
OCR_TARGETED_ZOOM=3.5
OCR_TARGETED_TIMEOUT_SEC=12
OMP_THREAD_LIMIT=1


OCR_MULTI_VARIANT=1
OCR_TESSERACT_OEM=1
OCR_FULL_PAGE=0

OCR_TARGETED_ALWAYS=1
LONG_TEXT_MAX_CHARS=8000
DOC_ID_POLICY=filename_stem
STRICT_NO_GUESS_MODE=true
ENABLE_LLM_BACKFILL_ON_MISSING=false
OCR_LANG=vie+eng
