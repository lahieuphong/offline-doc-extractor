+def ocr_pdf_targeted_region(
+    page,
+    page_index: int,
+    label: str,
+    crop_box_ratio: Tuple[float, float, float, float],
+    psm: str,
+) -> str:
+    """OCR one important page region: header/date/title or signature/footer.
+
+    Full-page OCR on scanned government documents can miss text hidden by stamps
+    or seals.  This targeted OCR is small, offline, and keeps the rest of the
+    application unchanged while improving metadata fields such as issuedDate,
+    subject, signer and Lưu code.
+    """
+    matrix = fitz.Matrix(OCR_TARGETED_ZOOM, OCR_TARGETED_ZOOM)
+    pix = page.get_pixmap(matrix=matrix, alpha=False)
+    image = Image.frombytes("RGB", [pix.width, pix.height], pix.samples)
+    width, height = image.size
+
+    left, top, right, bottom = crop_box_ratio
+    crop = image.crop((
+        max(0, int(width * left)),
+        max(0, int(height * top)),
+        min(width, int(width * right)),
+        min(height, int(height * bottom)),
+    ))
+
+    gray = ImageOps.grayscale(crop)
+    gray = ImageEnhance.Contrast(gray).enhance(2.0)
+
+    try:
+        text = pytesseract.image_to_string(
+            gray,
+            lang="vie+eng",
+            config=f"--psm {psm}",
+            timeout=OCR_TARGETED_TIMEOUT_SEC,
+        )
+    except RuntimeError:
+        text = "[OCR_TIMEOUT]"
+
+    return f"\n--- PAGE {page_index} {label} ---\n{text.strip()}"
+
